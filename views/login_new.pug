    body
        //style.
            body {
                background: url("!{loginImage}") center fixed
            }
        .center-logo.animated--fade-in-slow
            div
                img(src=`${(webconf.login_banner_overides) ? webconf.login_banner_overides : "/static/img/sequenzia-logo-nav.png"}`)
            if (stats)
                .center-logo-extra
                    .brags
                        if (stats.total_count)
                            .brag-count
                                span #{stats.total_count.toLocaleString('en-US')}+ Files
                        if (stats.total_data)
                            div
                                i.fas.fa-circle
                            .brag-size
                                if (stats.total_data > 1000000)
                                    span #{(stats.total_data / 1000000).toFixed(2).toLocaleString('en-US')} TB
                                else if (stats.total_data > 1000)
                                    span #{(stats.total_data / 1000).toFixed(2).toLocaleString('en-US')}GB
                                else if (stats.total_data > 1)
                                    span #{stats.total_data}MB
        if (Array.isArray(webconf.login_image_overides) && webconf.login_image_overides.length > 2)
            .slideshow-container(style=`width: ${webconf.login_image_overides.length * 100}vw; animation: slide ${webconf.login_image_overides.length * 45}s linear infinite`)
                each image, index in webconf.login_image_overides
                    if index < 2
                        .slideshow-image.lazyload(style=`background-image: url('${image}'`)
                    else
                        .slideshow-image.lazyload(data-bg=image)
            style.
                body {
                    background-image: url("!{webconf.login_image_overides[0]}") center fixed
                }
        else
            style.
                body {
                    background-image: url("!{loginImage}") center fixed
                }
        if (banner)
            .login-banner-holder
                .login-banner
                    span !{banner}
        .fixed-bottom
            if (owner)
                .bottom-owner
                    .owner-intro
                        span Administrated by:
                    //.owner-tag(style=`${(owner.banner) ? 'background-image: url("' + ((owner.banner_is_custom) ? cdn + 'user/banner/' + owner.banner : 'https://cdn.discordapp.com/banners/' + owner.id + '/' + owner.banner + ((owner.avatar.includes('a_')) ? '.gif?size=1024' : '.png?size=1024')) + '");': ''}`)
                    .owner-tag
                        img(src=`${(owner.avatar_is_custom) ? cdn + 'user/avatar/' + owner.avatar : 'https://cdn.discordapp.com/avatars/' + owner.id + '/' + owner.avatar + ((owner.avatar.includes('a_')) ? '.gif?size=128' : '.png?size=128') }`)
                        div
                            span !{owner.name}
                            a(href=`https://discordapp.com/channels/@me/${owner.id}/`)
                                i.fa-light.fa-message
                                span Contact
            else
                .bottom-logo
                    span Powered by:
                    img.bottom-logo(src="/static/img/sequenzia-logo-white.png")
            .bottom-data-plate
                span v22.0
        //if (stats)
            .fixed-top
                .brags_container
                    if (servers)
                        .server-grid-parent(style=`grid-template-columns: repeat(${servers.slice(0, 6).length}, minmax(100px, 50px));`)
                            for thisServer, thisServerIndex in servers.slice(0, 6)
                                .server-grid-child(style=`z-index: ${8 - thisServerIndex}`)
                                    img.server-icon(class=`${(webconf.square_server_icons_sidebar) ? 'rounded' : 'rounded-circle'}` title=`${thisServer.name}\n(${(thisServer.authware_enabled === 1) ? 'Login Server' : 'Storage'})` src=`https://cdn.discordapp.com/icons/${thisServer.serverid}/${thisServer.avatar}.png?size=128` id=`server-${thisServer.serverid}`)
        #container
            #inviteContainer
                if (login_banners)
                    .extraBanners
                        for banner in login_banners
                            .banner(onclick=`window.location.href = "${banner.url}"; return false;` style=`background-color: ${banner.background}; color: ${banner.color}`)
                                if (banner.text)
                                    div.holder.span
                                        img(src=banner.image)
                                        .text
                                            span !{banner.text}
                                else
                                    div.holder
                                        img(src=banner.image)
                                div.arrow
                                    i.fas.fa-chevron-right.pl-2
                .acceptContainer
                    .logo-container
                        img.top-logo(src=`${(webconf.login_banner_overides) ? webconf.login_banner_overides : "/static/img/sequenzia-logo-nav.png"}`)
                    .icon-holder
                        div
                            i.fas.fa-image
                        div
                            i.fas.fa-film
                        div
                            i.fas.fa-music
                        div
                            i.fas.fa-folder
                        div
                            i.fas.fa-archive
                    if (noLoginAvalible)
                        form(style='color: #ffffff; text-shadow: 0 0 20px #ff000070;').padding-top
                            if (noLoginAvalible === 'nomember')
                                i.fas.fa-passport.fa-7x.center(style='padding: 0;')
                                h3 No Passport
                                p Your account has no access rights, Check your roles in the server
                                .formContainer
                                    if (joinLink)
                                        .formDiv.center(style='margin-bottom: 15px;')
                                            a.acceptBtn(href=joinLink)
                                                i.fab.fa-discord
                                                span Register
                                    a.acceptBtn(href='/discord/destroy')
                                        i.fas.fa-sign-out-alt
                                        span Logout
                            else if (noLoginAvalible === 'esm_activated')
                                i.fas.fa-passport.fa-7x.center(style='padding: 0;')
                                h3 ESM Failure
                                p Enhanced security mode was tripped
                                p You login was aborted, please contact a system administrator
                                .formContainer
                                    .formDiv.center
                                        a.acceptBtn(href='/discord/destroy')
                                            i.fas.fa-sign-out-alt
                                            span Cancel
                            else if (noLoginAvalible === 'notelegram')
                                i.fas.fa-passport.fa-7x.center(style='padding: 0;')
                                h3 Account Not Found
                                p Your account was not found to be linked to a user, either you are not a member of the server or you need to link your account.
                                p If you are a member, login with discord, User Menu > Authentication > Login with Telegram
                                .formContainer
                                    if (joinLink)
                                        .formDiv.center
                                            a.acceptBtn(href=joinLink style='margin-bottom: 15px;')
                                                i.fab.fa-discord
                                                span Join Discord
                                    .formDiv.center
                                        a.acceptBtn(href='/discord/login')
                                            i.fab.fa-discord
                                            span Log in with Discord
                                    .formDiv.center
                                        a.acceptBtn(href='/discord/destroy')
                                            i.fas.fa-sign-out-alt
                                            span Cancel
                            else if (noLoginAvalible === 'noauth')
                                i.fas.fa-user-xmark.fa-7x.center(style='padding: 0;')
                                h3 No Permission
                                .formContainer
                                    .formDiv.center
                                        a.acceptBtn(href='/discord/destroy')
                                            i.fas.fa-sign-out-alt
                                            span Cancel
                            else
                                i.fas.fa-ban.fa-7x.center(style='padding: 0;')
                                h3 No Valid Membership
                                .formContainer
                                    .formDiv.center
                                        a.acceptBtn(href='/discord/destroy')
                                            i.fas.fa-sign-out-alt
                                            span Cancel

                    else if (authenticatedDevice)
                        form(style='color: #ffffff; text-shadow: 0 0 20px #ff000070;')
                            i.fas.fa-check-circle.fa-7x.center(style='padding: 0;')
                            h3 Your Ready!
                            .formContainer
                                .formDiv.center
                                    span.register
                                        span It may take up to a minute for the client to refresh, you can manually refresh if you want
                    else if (authfailedDevice)
                        form(style='color: #ffffff; text-shadow: 0 0 20px #ff000070;')
                            i.fas.fa-times-circle.fa-7x.center(style='padding: 0;')
                            h3 Login Failed, Try again.
                            .formContainer
                                .formDiv.center
                                    a.acceptBtn(href='/home')
                                        i.fas.fa-home
                                        span Go Home
                    else if (serverError)
                        form(style='color: #ffffff; text-shadow: 0 0 20px #ff000070;')
                            i.fas.fa-times-circle.fa-7x.center(style='padding: 0;')
                            h3 Internal Server Failure (#{serverError})
                            .formContainer
                                .formDiv.center
                                    a.acceptBtn(href='/home')
                                        i.fas.fa-home
                                        span Go Home
                    else
                        form(style='color: #460000;')
                            .formContainer
                                .formDiv.center
                                    if (login_image || login_code)
                                        div#collapseQRCode.login-qr.collapse(style='display: none')
                                            if (login_code)
                                                div.login-code
                                                    span.login-code.text-capitalize #{login_code}
                                            if (login_image)
                                                img(src=login_image style='padding-bottom: 1em;')
                                    div.login-button
                                        a.acceptBtn(href='/discord/login')
                                            i.fas.fa-key
                                            span Login
                                        if (show_user_list)
                                            a.acceptBtn(href='/discord/users')
                                                i.fas.fa-key
                                                span Impersonate
                                        if (login_image || login_code)
                                            a.acceptBtn(href='#_' title="Use Express Login code or QR Code to login via another device that is already logged in" onclick="$('#collapseQRCode').toggle(); return false;")
                                                i.fas.fa-copy
                                                span Transfer

                                    if (joinLink)
                                        span.register
                                            a(href=joinLink) Requires a valid membership
    if (login_image)
        script.
            setInterval(function () {
                $.ajax({async: true,
                    url: '/device-login?checklogin=true',
                    type: "GET",
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        if (response === 'true') {
                            location.href = '/discord/refresh'
                        }
                    },
                    error: function (response) {
                    }
                });
            }, 60000);
            setTimeout(() => {
                document.querySelectorAll(".lazyload").forEach(entry => {
                    const div = entry;
                    const bgImage = div.getAttribute("data-bg");
                    if (bgImage) {
                        div.style.backgroundImage = `url('${bgImage}')`;
                        div.removeAttribute("data-bg");
                    }
                });
            }, 10000);
