html
    head
        meta(charset='utf-8')
        meta(http-equiv='X-UA-Compatible', content='IE=edge')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=yes, viewport-fit=cover')
        meta(name='description', content=webconf.site_name || 'Sequenzia')
        meta(name='author', content='Yukimi Kazari')
        meta(name="apple-mobile-web-app-capable" content="yes")
        meta(name="apple-mobile-web-app-title" content=webconf.site_name || "Sequenzia")
        meta(name="apple-mobile-web-app-status-bar-style" content="black-translucent")
        link(rel='apple-touch-icon' sizes='180x180' href='/static/img/icons/android/android-launchericon-192-192.png')
        link(rel='icon' type='image/png' sizes='32x32' href='/static/img/icons/firefox/firefox-general-32-32.png')
        link(rel='icon' type='image/png' sizes='16x16' href='/static/img/icons/chrome/firefox-general-16-16.png')
        link(rel='preload', href="/static/font/london2012.woff2" as="font" type="font/woff2" crossorigin="crossorigin")
        link(rel='preload', href="/static/font/weathericons-regular-webfont.woff2" as="font" type="font/woff2" crossorigin="crossorigin")
        link(rel='preload', href="/static/vendor/fontawesome/webfonts/fa-brands-400.woff2" as="font" type="font/woff2" crossorigin="crossorigin")
        link(rel='preload', href="/static/vendor/fontawesome/webfonts/fa-regular-400.woff2" as="font" type="font/woff2" crossorigin="crossorigin")
        link(rel='preload', href="/static/vendor/fontawesome/webfonts/fa-light-300.woff2" as="font" type="font/woff2" crossorigin="crossorigin")
        link(rel='preload', href="/static/vendor/fontawesome/webfonts/fa-thin-100.woff2" as="font" type="font/woff2" crossorigin="crossorigin")
        link(rel='preload', href="/static/vendor/fontawesome/webfonts/fa-solid-900.woff2" as="font" type="font/woff2" crossorigin="crossorigin")
        link(rel='preload', href="/static/vendor/fontawesome/webfonts/fa-duotone-900.woff2" as="font" type="font/woff2" crossorigin="crossorigin")
        link(rel='manifest' href='/static/manifest.json')
        title= `${webconf.site_name}`
        link(rel='stylesheet', href='/static/css/sb-admin-2.min.css')
        link(rel='stylesheet', href='/static/css/weather-icons.min.css')
        link(rel='stylesheet', href="/static/vendor/fontawesome/css/fontawesome.min.css")
        link(rel='stylesheet', href="/static/vendor/fontawesome/css/all.min.css")
        link(rel="stylesheet", href="https://fonts.googleapis.com/css?family=Yantramanav:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i")
        link(rel="stylesheet", href="/css/custom.min.css")
        link(rel="stylesheet", href="/static/css/instance-custom.css")
        link(rel="stylesheet", href="/css/ambient.min.css")
        link(rel="stylesheet", href="/static/css/instance-ambient.css")
        style.
            .background-image {
                transform: none;
            }
    body
        #exitOverlay.animated--fade-in.align-items-center.justify-content-center.d-none
            img#exitImage(src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=")
        #deadzoneOverlay
        #roundedOverlay
        #overlayCycle
        #overlayBg.background-image.overlay
        #overlayLeft.background-image.overlay-left.d-none
        #bg1.background-image(style=`opacity: 1; z-index: -101!important; background-image: url('/static/img/ambient-default.png');`)
        #bg2.background-image(style=`opacity: 0; z-index: -103!important; background-image: url('#_');`)
        img#bg1port.portait-overlay.center-block(style='z-index: -100!important; opacity: 0;')
        img#bg2port.portait-overlay.center-block(style='z-index: -102!important; opacity: 0;')
        img#imageHolder.position-absolute.fixed-top(style='z-index: -500!important;' crossOrigin="Anonymous")
        canvas#imageCanvas.position-absolute.fixed-top(style='z-index: -500!important;')
        img#ChunSystemPlate.position-absolute.bottom-right.hidden(style='botton: 0; right: 0;' src='data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==')


        #content-wrapper.container.p-4
            .fixed-bottom
                #errorBanner
            .fixed-bottom.m-5.animated--fade-in.hidden-on-boot(style="z-index: 1031;")
                #kioskToolbarButtons.d-none
                    .kiosk-buttons-container.d-flex.flex-row.align-items-left
                        span.p-4 Kiosk Config, No Data
            .fixed-top.m-5.animated--fade-in.hidden-on-boot
                #kioskRemoteButtons.d-none
                    .kiosk-buttons-container.d-flex.flex-column.align-items-center
                        span.p-4 Invalid Kiosk Config
            .fixed-top.m-5.animated--fade-in.hidden-on-boot.align-items-start.d-flex
                #logoTop.d-none.justify-content-end.pr-4(style='opacity: .6')
                    img.shadow-txt.text-white(style="width: 280px;position: relative;top: 0.2em;" src=`/static/img/sequenzia-logo-nav.png`)
                #warningBox.warning-box-contents.d-none.justify-content-end
                    .align-items-center.d-flex
                        i#warningIcon.pr-2.fas.fa-search
                        span#warningText This is just a test
                #displayInfo.d-flex.justify-content-end.hover-show.ml-auto.d-none(style='opacity: .4;')
                    span#displayName.align-self-center(style='font-size: 1.6em; color: white; font-weight: 300; padding: 0 0.5em 0 0; -webkit-text-stroke: 1px #00000069; text-shadow: 0px 0px 10px #000000a6;')
                #userInfo.d-flex.justify-content-end.hover-show.ml-auto(style='opacity: .4;')
                    span.align-self-center(style='font-size: 1.6em; color: white; font-weight: 300; padding: 0 0.5em 0 0; -webkit-text-stroke: 1px #00000069; text-shadow: 0px 0px 10px #000000a6;') #{user.username}
                    a#userDropdown.pr-0(href='#_' role='button' data-toggle='dropdown' aria-haspopup='true' aria-expanded='false')
                        img.img-profile.rounded-circle(src=user.avatar style='width: 2.5em; box-shadow: 0 0 8px black; -webkit-text-stroke: 1px #00000069; text-shadow: 0px 0px 10px #000000a6;')
                    // Dropdown - User Information
                    .dropdown-menu.dropdown-menu-tas.shadow(aria-labelledby='userDropdown')
                        a.dropdown-item.only-standalone(title="Reload Application" href='#_' onclick='location.reload(); return false;')
                            i.fas.fa-sync.fa-sm.fa-fw.mr-2
                            | Restart App
                        a.dropdown-item(href='#_' data-toggle='modal' data-target='#logoutModal').text-danger
                            i.fas.fa-sign-out-alt.fa-sm.fa-fw.mr-2.text-danger
                            | Logout
            #BottomSestion.fixed-bottom.d-flex.m-5
                .flex-grow-1.align-self-end(style='opacity: .6').animated--fade-in.hidden-on-boot
                    img#logoStart.shadow-txt.text-white(style="width: 280px;position: relative;top: 0.2em;" src=`/static/img/sequenzia-logo-nav.png`)
                #sideData.justify-content-end.flex-column.d-flex.pr-4
                    #dateInfo.clock-date.clock.ml-auto.animated--fade-in.hidden-on-boot
                        span#day.shadow-txt
                        span#date.pl-2.shadow-txt
                    .ml-auto.d-flex.animated--fade-in.hidden-on-boot
                        #weatherInfo.weather.d-flex.align-items-end.mb-2.hidden
                            #weatherData
                                .pr-1.text-end
                                    span#weatherDataCond.text-uppercase.hidden
                                    #weatherLoHi.text-end.hidden
                                        span#weatherDataLo
                                        i.weather-format.wi.wi-degrees
                                        .d-inline-block
                                            i.fas.fa-circle.mb-1.shadow-txt(style='margin: 0 1em 0.5em 1em;font-size: 6px;vertical-align: middle;line-height: 0.1em;')
                                        span#weatherDataHi
                                        i.weather-format.wi.wi-degrees
                                .text-end.current-weather
                                    .d-inline-flex
                                        span#weatherDataTemp
                                        i#weatherFormat.weather-format.align-text-top.wi
                            #weatherIcon.ml-2
                                i#weatherIconMin
                        #timeInfo.clock-time.clock
                            span#time.shadow-txt
                    #dataInfo.ml-auto.pt-1(style='opacity: 0.4; font-size: 1.3rem; font-weight: 100;')
                        .d-inline-flex.animated--fade-in.hidden-on-boot
                            i#dataFav.shadow-txt.fas.fa-star.shadow-txt.align-self-center.d-none(style='font-size: 16px; vertical-align: middle;')
                            i#dataIcon.shadow-txt.fas.fa-search.shadow-txt.align-self-center.d-none(style='font-size: 16px; vertical-align: middle; opacity: 0.25;')
                        span#data2.shadow-txt.pr-2.pl-1(style='opacity: 0.25')
                        span#data3.shadow-txt Booting...
                        .d-inline-block.p-2.align-self-center.animated--fade-in.hidden-on-boot
                            i.fas.fa-circle.shadow-txt(style='font-size: 8px; vertical-align: middle;')
                        span#data1.text-capitalize.shadow-txt.animated--fade-in.hidden-on-boot
                    #logoEnd.ml-auto.pt-2.d-none(style='opacity: .6').animated--fade-in.hidden-on-boot
                        img.shadow-txt.text-white(style="width: 280px;position: relative;top: 0.2em;" src=`/static/img/sequenzia-logo-nav.png`)
            #ChunInfo.fixed-bottom.d-flex.animated--fade-in.hidden
                #ChunInfoData.flex-grow-1.px-3.d-flex
                #ChunInfoHolder.px-3.d-flex
            #ChunCotroller.fixed-bottom.d-flex.hidden
                #ChunTextOverlays.d-flex
                #ChunBackground.d-flex.position-fixed
