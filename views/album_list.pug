div
    if (albums && albums.length > 0 )
        if (manageMode)
            #albumManager.accordion
                each album in albums
                    .card.album-menu
                        div(id=`album-${album.aid}-Menu` data-toggle="collapse" data-target=`#album-${album.aid}-Collapse`).card-header.d-flex.collapsed
                            div.pr-2
                                if (album.uri === 'gallery')
                                    i.fas.fa-photo-video
                                else if (album.uri === 'files')
                                    i.fas.fa-folder
                                else if (album.uri === 'cards')
                                    i.fas.fa-envelope
                                else
                                    i.fas.fa-question
                            span.mr-auto #{album.name}
                            span.pr-2 (ID: #{album.aid})
                            div.pl-2
                                if (album.privacy === 1)
                                    i.fas.fa-lock
                                else if (album.privacy === 2)
                                    i.fas.fa-link
                                else
                                    i.fas.fa-globe-americas
                        div.collapse(aria-labelledby=`album-${album.aid}-Menu` data-parent=`#albumManager` id=`album-${album.aid}-Collapse`)
                            .card-body.album-menu
                                div.form-row
                                    div.form-group.col.col-12
                                        input.form-control(type="text" placeholder="My Wallpapers" id=`album-${album.aid}-Text` value=album.name)
                                div.form-row
                                    div.form-group.col-6
                                        select.form-control(id=`album-${album.aid}-Type`)
                                            if (album.uri === 'gallery')
                                                option(value='0' selected) Gallery
                                            else
                                                option(value='0') Gallery
                                            if (album.uri === 'files')
                                                option(value='1' selected) Files
                                            else
                                                option(value='1') Files
                                            if (album.uri === 'cards')
                                                option(value='2' selected) Cards
                                            else
                                                option(value='2') Cards
                                    div.form-group.col-6
                                        select.form-control(id=`album-${album.aid}-Privacy`)
                                            if (album.privacy === 1)
                                                option(value='1' selected) Private
                                            else
                                                option(value='1') Private
                                            if (album.privacy === 0)
                                                option(value='0' selected) Public
                                            else
                                                option(value='0' ) Public
                                            if (album.privacy === 2)
                                                option(value='2' selected) Unlisted
                                            else
                                                option(value='2') Unlisted
                                div.form-row
                                    a#albumCreateButton.btn.btn-primary.mr-auto(href='#_' onclick=`getNewContent([], [['album', '${album.aid}']], "/${album.uri}"); return false;`)
                                        if (album.uri === 'gallery')
                                            i.pr-2.fas.fa-photo-video
                                        else if (album.uri === 'files')
                                            i.pr-2.fas.fa-folder
                                        else if (album.uri === 'cards')
                                            i.pr-2.fas.fa-envelope
                                        else
                                            i.pr-2.fas.fa-question
                                        | View
                                    a#albumCreateButton.btn.btn-danger.mr-1(href='#_' onclick=`deleteAlbum("${album.aid}"); return false;`)
                                        i.pr-2.fas.fa-trash-alt
                                        | Delete
                                    a#albumCreateButton.btn.btn-success.ml-1.mr-1(href='#_' onclick=`updateAlbum("${album.aid}"); return false;` )
                                        i.pr-2.fas.fa-edit
                                        | Update
        else
            .list-group
                each album in albums
                    - classList = ''
                    if (album.found_aid)
                        - classList = 'active'
                    div.list-group-item.d-flex.list-group-item.list-group-item-action(class=classList).justify-content-between.p-0
                        a.inner-item.w-100.d-flex.align-items-center(href='#_' onclick=`toggleAlbumItem("${album.aid}"${(id) ? ', "' + id + '"' : ''}); return false;` class=`${(album.found_aid) ? 'pr-0' : ''}`)
                            div.pr-2
                                if (album.uri === 'gallery')
                                    i.fas.fa-photo-video
                                else if (album.uri === 'files')
                                    i.fas.fa-folder
                                else if (album.uri === 'cards')
                                    i.fas.fa-envelope
                                else
                                    i.fas.fa-question
                            span.mr-auto #{album.name}
                            if (album.found_aid)
                                div.pl-2
                                    i.fas.fa-check-circle
                            div.pl-2
                                if (album.privacy === 1)
                                    i.fas.fa-lock
                                else if (album.privacy === 2)
                                    i.fas.fa-link
                                else
                                    i.fas.fa-globe-americas
                        if (album.found_aid && id)
                            a.inner-item.d-flex.align-items-center(href='#_' onclick=`bumpAlbumItem("${album.aid}", "${id}"); return false;`)
                                i.fas.fa-up-to-line
